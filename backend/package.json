    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "eslint": "^8.57.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
